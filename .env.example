# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: Your Supabase project URL.
VITE_SUPABASE_URL=""

# SUPABASE_ANON_KEY: Your Supabase project anonymous key.
VITE_SUPABASE_ANON_KEY=""

# SUPABASE_SERVICE_ROLE_KEY: Your Supabase project service role key.
# This key has administrative access and should NEVER be exposed to the client.
SUPABASE_SERVICE_ROLE_KEY=""

# EMAIL_HOST: SMTP server address (e.g., smtp.gmail.com)
EMAIL_HOST=""
# EMAIL_PORT: SMTP server port (e.g., 587 for TLS, 465 for SSL)
EMAIL_PORT="587"
# EMAIL_USER: SMTP username (usually your email address)
EMAIL_USER=""
# EMAIL_PASS: SMTP password or App Password
EMAIL_PASS=""
# EMAIL_SECURE: Set to 'true' for port 465, 'false' for others
EMAIL_SECURE="false"
